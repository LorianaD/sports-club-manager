{% extends 'base.html.twig' %}

{% block title %}Modifier l' absence{% endblock %}

{% block header %}
<div class="player-create__wrapper">
    {% include "layout/header/_dashboard_page_topbar.html.twig" with {
        title: "Modification de l' absence",
        backPath: path('attendance_show', {
            id: attendance.id,
        }),
        img: '✕'
    } %}
{% endblock %}
{% block body %}
    <main class="player-create">

        {% include "attendance/form/_form.html.twig" with {
            formName: formEditattendance,
            returnPath: path('attendance_show', {
                id: attendance.id
            }),
        } %}

    </main>
</div>
{% endblock %}
{% block footer %}
    {% include "layout/dashboardFooter.html.twig" %}
{% endblock %}