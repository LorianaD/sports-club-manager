{% extends 'base.html.twig' %}

{% block title %}Absence{% endblock %}

{% block header %}
    {% include "layout/header/_dashboard_page_topbar.html.twig" with {
        title: 'Gestion des absences',
        actionPath: path('attendance_new'),
        actionLabel: '+'
    } %}
{% endblock %}

{% block body %}
    <main class="dashboard-main">
        <div class="">
            {# STATS #}
        </div>

        <section class="dashboard-card">

            {% if attendances %}

                <ul class="card-list">

                    {% for attendance in attendances %}

                        <li class="card-list__item">
                            <a class="card-list__link sanction-list__link" href="{{ path('attendance_show', { 'id' : attendance.id }) }}">
                                <div class="player-avatar">
                                    {{ attendance.player.firstname|slice(0,1) }}{{ attendance.player.lastname|slice(0,1) }}
                                </div>
                                <div class="sanction-list__info">
                                    <h3 class="card-list__title">{{ attendance.player.firstname }} {{ attendance.player.lastname }}</h3>
                                    <p class="card-list__description">
                                        <span>{{ attendance.reason }}</span> • <span>{{ attendance.createAt|date('d/m') }}</span>
                                    </p>
                                </div>
                            </a>
                            <div>
                                
                                {% include "attendance/partials/_attendance_badge.html.twig" with {
                                    status: attendance.AttendanceStatus.label
                                } %}
                                
                            </div>
                        </li>

                    {% endfor %}

                </ul>
            
            {% else %}

                <p class="empty-state">Aucun joueur enregistré - Commencé l'enregistrement</p>
            
            {% endif %}
            
        </section>
        
    </main>
{% endblock %}

{% block footer %}
    {% include "layout/dashboardFooter.html.twig" %}
{% endblock %}