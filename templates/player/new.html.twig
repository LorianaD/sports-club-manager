{% extends 'base.html.twig' %}

{% block title %}Nouveau joueur — Identité{% endblock %}

{% block header %}
<div class="player-create__wrapper">
    {% include "layout/header/_dashboard_page_topbar.html.twig" with {
        title: 'Nouveau joueur',
        backPath: path('player_index'),
        img: '✕'
    } %}
{% endblock %}
{% block body %}
    <main class="player-create">

        {% if step == 1 %}

            {% include "player/forms/_createPlayer.html.twig" with {
                newPlayerForm: newPlayerForm,
                next: 'Suivant',
                return: 'Annuler'
            }%}

        {% elseif step == 2 %}
            {% include "player/forms/_createContact.html.twig" with {
                newContactForm: newContactForm,
                newRelationForm: newRelationForm,
                formAction: path('player_new', { step: 2, playerId: playerId }),
                returnPath: path('player_new', { step: 1, playerId: playerId }),
                next: 'Suivant',
                return: 'Retour'
            } %}
        {% elseif step == 3 %}
            {% include "player/forms/_createTeam.html.twig" with {
                newTeamForm: newTeamForm,
                formAction: path('player_new', { step: 3, playerId: playerId }),
                returnPath: path('player_new', { step: 2, playerId: playerId }),
                next: 'Validé',
                return: 'Retour'
            } %}            
        {% endif %}

    </main>
</div>
{% endblock %}
{% block footer %}
    {% include "layout/dashboardFooter.html.twig" %}
{% endblock %}