{{ form_start(newPlayerForm, { attr: { class: 'player-create__form' } }) }}
    
    <div class="player-create_card">

        {# <div class="player-create__photo">
            <div class="player-create__photo-placeholder">
                <span class="player-create__photo-placeholder-icon">📷</span>
                <span class="player-create__photo-placeholder-label">Photo</span>
            </div>
            <div class="player-create__photo-info">
                <p class="player-create__photo-title">Photo du joueur</p>
                <p class="player-create__photo-hint">JPG, PNG · max 5 Mo</p>
                {{ form_widget(newPlayerForm.photo, {
                    attr: { class: 'player-create__input', style: 'display:none', id: 'player_photo' }
                }) }}
                <label for="player_photo" class="player-create__photo-btn">
                    Choisir une photo
                </label>
            </div>
        </div> #}
    
        <section class="player-create__section">

            <div class="player-create__section-header">
                <span class="player-create__section-line"></span>
                <span class="player-create__section-label">
                    <span class="player-create__section-dot"></span>
                    Identité
                </span>
                <span class="player-create__section-line"></span>
            </div>

            <div class="player-create_row">

                <div class="player-create__field">
                    {{ form_label(newPlayerForm.lastname, 'Nom', { label_attr: { class: 'form-body_label' } }) }}
                    {{ form_widget(newPlayerForm.lastname, { attr: { class: 'form-body_input' } }) }}
                </div>

                <div class="player-create__field">
                    {{ form_label(newPlayerForm.firstname, 'Prénom', { label_attr: { class: 'form-body_label' } }) }}
                    {{ form_widget(newPlayerForm.firstname, { attr: { class: 'form-body_input' } }) }}
                </div>

            </div>

            <div class="player-create__field">
                {{ form_label(newPlayerForm.birth_date, 'Date de naissance', { label_attr: { class: 'form-body_label' } }) }}
                {{ form_widget(newPlayerForm.birth_date, { attr: { class: 'form-body_input' } }) }}
            </div>                

        </section>

        <section class="player-create_section">

            <div class="player-create__section-header">
                <span class="player-create__section-line"></span>
                <span class="player-create__section-label">
                    <span class="player-create__section-dot"></span>
                    Coordonnées
                </span>
                <span class="player-create__section-line"></span>
            </div>

            <div class="player-create__field">
                {{ form_label(newPlayerForm.phone_number, 'Numéro de téléphone', { label_attr: { class: 'form-body_label' } }) }}
                {{ form_widget(newPlayerForm.phone_number, { attr: { class: 'form-body_input', placeholder: '06 12 34 56 78' } }) }}
            </div>            

            <div class="player-create__field">
                {{ form_label(newPlayerForm.email, 'Email', { label_attr: { class: 'form-body_label' } }) }}
                {{ form_widget(newPlayerForm.email, { attr: { class: 'form-body_input' } }) }}
            </div>

            <div class="player-create__field">
                {{ form_label(newPlayerForm.address, 'Adresse', { label_attr: { class: 'form-body_label' } }) }}
                {{ form_widget(newPlayerForm.address, { attr: { class: 'form-body_input' } }) }}
            </div>

            <div class="player-create_row">

                <div class="player-create__field">
                    {{ form_label(newPlayerForm.pc, 'Code postale', { label_attr: { class: 'form-body_label' } }) }}
                    {{ form_widget(newPlayerForm.pc, { attr: { class: 'form-body_input' } }) }}
                </div>

                <div class="player-create__field">
                    {{ form_label(newPlayerForm.city, 'Ville', { label_attr: { class: 'form-body_label' } }) }}
                    {{ form_widget(newPlayerForm.city, { attr: { class: 'form-body_input' } }) }}
                </div>

            </div>
        </section>

        <div class="player-create__field">
            {{ form_label(newPlayerForm.license_number, 'Numéro de license', { label_attr: { class: 'form-body_label' } }) }}
            {{ form_widget(newPlayerForm.license_number, { attr: { class: 'form-body_input' } }) }}
        </div>

        <div class="player-create__field">
            {{ form_label(newPlayerForm.number, 'Numéro de maillot', { label_attr: { class: 'form-body_label' } }) }}
            {{ form_widget(newPlayerForm.number, { attr: { class: 'form-body_input' } }) }}
        </div> 

        <div class="player-create_actions">
            <a href="{{ path('player_index') }}" class="btn btn-secondary">
                {{ return }}
            </a>
            <button type="submit" class="btn btn-principal">
                {{ next }}
            </a>
        </div>
        
    </div>

{{ form_end(newPlayerForm) }}