{% extends 'base.html.twig' %}

{% block title %}Nouveau joueur — Identité{% endblock %}

{% block header %}
<div class="player-create__wrapper">
    <header class="header dashboard-header">

        <a href="{{ path('player_show', {'id' : player.id }) }}">
            ✕
        </a>

        <h2 class="dashboard-header_title">
            Nouveau joueur
        </h2>
        <a class="dashboard-header_add" href="{{ path('player_new') }}">
            
        </a>
    </header>
{% endblock %}
{% block body %}
    <main class="player-create">
        {{ form_start(editPlayerForm, { attr: { class: 'player-create__form' } }) }}
            
            <div class="player-create_card">

                {# <div class="player-create__photo">
                    <div class="player-create__photo-placeholder">
                        <span class="player-create__photo-placeholder-icon">📷</span>
                        <span class="player-create__photo-placeholder-label">Photo</span>
                    </div>
                    <div class="player-create__photo-info">
                        <p class="player-create__photo-title">Photo du joueur</p>
                        <p class="player-create__photo-hint">JPG, PNG · max 5 Mo</p>
                        {{ form_widget(editPlayerForm.photo, {
                            attr: { class: 'player-create__input', style: 'display:none', id: 'player_photo' }
                        }) }}
                        <label for="player_photo" class="player-create__photo-btn">
                            Choisir une photo
                        </label>
                    </div>
                </div> #}
            
                <section class="player-create__section">

                    <div class="player-create__section-header">
                        <span class="player-create__section-line"></span>
                        <span class="player-create__section-label">
                            <span class="player-create__section-dot"></span>
                            Identité
                        </span>
                        <span class="player-create__section-line"></span>
                    </div>

                    <div class="player-create_row">

                        <div class="player-create__field">
                            {{ form_label(editPlayerForm.lastname, 'Nom', { label_attr: { class: 'form-body_label' } }) }}
                            {{ form_widget(editPlayerForm.lastname, { attr: { class: 'form-body_input' } }) }}
                        </div>

                        <div class="player-create__field">
                            {{ form_label(editPlayerForm.firstname, 'Prénom', { label_attr: { class: 'form-body_label' } }) }}
                            {{ form_widget(editPlayerForm.firstname, { attr: { class: 'form-body_input' } }) }}
                        </div>

                    </div>

                    <div class="player-create__field">
                        {{ form_label(editPlayerForm.birth_date, 'Date de naissance', { label_attr: { class: 'form-body_label' } }) }}
                        {{ form_widget(editPlayerForm.birth_date, { attr: { class: 'form-body_input' } }) }}
                    </div>                

                </section>

                <section class="player-create_section">

                    <div class="player-create__section-header">
                        <span class="player-create__section-line"></span>
                        <span class="player-create__section-label">
                            <span class="player-create__section-dot"></span>
                            Coordonnées
                        </span>
                        <span class="player-create__section-line"></span>
                    </div>

                    <div class="player-create__field">
                        {{ form_label(editPlayerForm.phone_number, 'Numéro de téléphone', { label_attr: { class: 'form-body_label' } }) }}
                        {{ form_widget(editPlayerForm.phone_number, { attr: { class: 'form-body_input', placeholder: '06 12 34 56 78' } }) }}
                    </div>            

                    <div class="player-create__field">
                        {{ form_label(editPlayerForm.email, 'Email', { label_attr: { class: 'form-body_label' } }) }}
                        {{ form_widget(editPlayerForm.email, { attr: { class: 'form-body_input' } }) }}
                    </div>

                    <div class="player-create__field">
                        {{ form_label(editPlayerForm.address, 'Adresse', { label_attr: { class: 'form-body_label' } }) }}
                        {{ form_widget(editPlayerForm.address, { attr: { class: 'form-body_input' } }) }}
                    </div>

                    <div class="form-body__address">

                        <div class="player-create__field">
                            {{ form_label(editPlayerForm.pc, 'Code postale', { label_attr: { class: 'form-body_label' } }) }}
                            {{ form_widget(editPlayerForm.pc, { attr: { class: 'form-body_input' } }) }}
                        </div>

                        <div class="player-create__field">
                            {{ form_label(editPlayerForm.city, 'Ville', { label_attr: { class: 'form-body_label' } }) }}
                            {{ form_widget(editPlayerForm.city, { attr: { class: 'form-body_input' } }) }}
                        </div>

                    </div>
                </section>

                <div class="player-create__field">
                    {{ form_label(editPlayerForm.license_number, 'Numéro de license', { label_attr: { class: 'form-body_label' } }) }}
                    {{ form_widget(editPlayerForm.license_number, { attr: { class: 'form-body_input' } }) }}
                </div>

                <div class="player-create__field">
                    {{ form_label(editPlayerForm.number, 'Numéro de maillot', { label_attr: { class: 'form-body_label' } }) }}
                    {{ form_widget(editPlayerForm.number, { attr: { class: 'form-body_input' } }) }}
                </div> 

                <div class="player-create_actions">
                    <button class="btn btn-principal">Créer le compte</button>
                </div>
                
            </div>

        {{ form_end(editPlayerForm) }}
        
    </main>
</div>
{% endblock %}
