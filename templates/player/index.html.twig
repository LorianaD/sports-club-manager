{% extends 'base.html.twig' %}

{% block title %}Joueurs{% endblock %}

{% block header %}
    {% include "layout/header/_dashboard_page_topbar.html.twig" with {
        title: 'Joueurs',
        actionPath: path('player_new'),
        actionLabel: '+'
    } %}
{% endblock %}

{% block body %}
    <main class="dashboard-main">
        <div class="">
            {# SEARCH AND FILTRES #}
        </div>

        <section class="dashboard-card">

            {% if players %}

                <ul class="card-list">

                    {% for player in players %}

                        <li class="card-list__item">
                            <a class="card-list__link" href="{{ path('player_show', { 'id' : player.id }) }}">
                                <div class="player-avatar">
                                    {{ player.firstname|slice(0,1) }}{{ player.lastname|slice(0,1) }}
                                </div>
                                <div>
                                    <h3 class="card-list__title">{{ player.firstname }} {{ player.lastname }}</h3>
                                    <p class="card-list__description"><span>{{ player.team.name|default('Aucune équipe') }}</span> · <span>
                                        {% if player.position is not empty %}
                                            {{ player.position|first.name }}
                                        {% else %}
                                            Aucun poste
                                        {% endif %}
                                    </span> · <span>#{{ player.number|default('N° non renseigné') }}</span></p>
                                </div>
                                <div>
                                
                                </div>
                            </a>
                            {% include "partials/_delete.html.twig" with {
                                pathAction: path("player_delete", { id: player.id }),
                                id: player.id
                            } %}
                        </li>

                    {% endfor %}

                </ul>
            
            {% else %}

                <p class="empty-state">Aucun joueur enregistré - Commencé l'enregistrement</p>
            
            {% endif %}
            
        </section>
        
    </main>
{% endblock %}
{% block footer %}
    {% include "layout/dashboardFooter.html.twig" %}
{% endblock %}