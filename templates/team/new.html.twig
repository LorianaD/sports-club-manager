{% extends 'base.html.twig' %}

{% block title %}Nouvelle équipe — Identité{% endblock %}

{% block header %}
<div class="player-create__wrapper">
    {% include "layout/header/_dashboard_page_topbar.html.twig" with {
        title: 'Nouvelle équipe',
        backPath: path('team_index'),
        img: '✕'
    } %}
{% endblock %}
{% block body %}
    <main class="player-create">

        {{ form_start(newTeamForm, { attr: { class: 'player-create__form' } }) }}
            <div class="player-create_card">
                <section class="player-create__section">
                    <div class="player-create__field">
                        {{ form_label(newTeamForm.name, "Nom de l'équipe", { label_attr: { class: 'form-body_label' } }) }}
                        {{ form_widget(newTeamForm.name, { attr: { class: 'form-body_input' } }) }}
                    </div>
                    <div class="player-create__field">
                        {{ form_label(newTeamForm.category, "Categorie", { label_attr: { class: 'form-body_label' } }) }}
                        {{ form_widget(newTeamForm.category, { attr: { class: 'form-body_input' } }) }}
                    </div>
                </section>
                <div class="player-create_actions">
                    <a href="{{ path('team_index') }}" class="btn btn-secondary">
                        Annulé
                    </a>
                    <button type="submit" class="btn btn-primary">
                        Validé
                    </a>
                </div>
            </div>
        {{ form_end(newTeamForm) }}

    </main>
</div>
{% endblock %}
{% block footer %}
    {% include "layout/dashboardFooter.html.twig" %}
{% endblock %}