{% extends 'base.html.twig' %}

{% block title %}Modifier l'entraînement{% endblock %}

{% block header %}
<div class="player-create__wrapper">
    {% include "layout/header/_dashboard_page_topbar.html.twig" with {
        title: "Modification de l' absence",
        backPath: path('events_show', {
            id: event.id,
        }),
        img: '✕'
    } %}
{% endblock %}
{% block body %}
    <main class="player-create">

        {% include "events/partials/_form.html.twig" with {
            formName: editEventForm,
            returnPath: path('events_show', {
                id: event.id
            }),
        } %}

    </main>
</div>
{% endblock %}
{% block footer %}
    {% include "layout/dashboardFooter.html.twig" %}
{% endblock %}