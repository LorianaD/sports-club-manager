{% extends 'base.html.twig' %}

{% block title %}Nouveaux événement{% endblock %}

{% block header %}
<div class="player-create__wrapper">
    {% include "layout/header/_dashboard_page_topbar.html.twig" with {
        title: 'Nouveaux événement',
        backPath: path('events_index'),
        img: '✕'
    } %}
{% endblock %}
{% block body %}
    <main class="player-create">

        {% include "events/partials/_form.html.twig" with {
            formName: newEventForm,
            returnPath: path('events_index'),
        } %}

    </main>
</div>
{% endblock %}
{% block footer %}
    {% include "layout/dashboardFooter.html.twig" %}
{% endblock %}