{% extends "base.html.twig" %}

{% block header %}
    {% include "layout/header/_dashboard_page_topbar.html.twig" with {
        title: "Fiche de l'entrainement",
        backPath: path('events_index'),
        img: '←',
        actionPath: path('events_edit', { id: event.id }),
        actionLabel: '<img src="' ~ asset('images/icons/edit.png') ~ '" alt="edit" class="dashboard-topbar_cta-img">',
        actionText: 'Modifier',
        deletePath: path('events_delete', { id: event.id }),
        id: event.id
    } %}
{% endblock %}
{% block body %}
    <main class="dashboard-main">
        <section class="sanction-show">

            <div class="sanction-show__hero">
                
                <div class="sanction-show__header">
                    <span class="sanction-show__label">Evénement</span>
                    <h3 class="sanction-show__title">
                        {{ event.name }}
                    </h3>
                </div>

            </div>

            <div class="sanction-show__content">

                <div class="sanction-show__row">
                    <span class="sanction-show__name">Date et heure</span>
                    <span class="sanction-show__value">{{ event.date|date('d/m/Y à H:i') }}</span>
                </div>

                <div class="sanction-show__row">
                    <span class="sanction-show__name">Lieu</span>
                    <span class="sanction-show__value">
                        {{ event.location|default('Aucune lieu encore renseignée') }}
                    </span>
                </div>

                <div class="sanction-show__row">
                    <span class="sanction-show__name">Participant - Administratif</span>
                    <span class="sanction-show__value">
                        {% for user in event.user %}
                            {{ user.firstname }} {{ user.lastname }}{% if not loop.last %}, {% endif %}
                        {% else %}
                            Aucun participant administratif
                        {% endfor %}
                    </span>
                </div>

                <div class="sanction-show__row">
                    <span class="sanction-show__name">Participant - Equipes</span>
                    <span class="sanction-show__value">
                        {% for team in event.teams %}
                            {{ team.name }}{% if not loop.last %}, {% endif %}
                        {% else %}
                            Aucune équipe participante
                        {% endfor %}
                    </span>
                </div>

                <div class="sanction-show__reason">
                    <span class="sanction-show__name">Note</span>
                    <p class="sanction-show__text">
                        {{ event.description }}
                    </p>
                </div>
            </div>
            
        </section>
    </main>
{% endblock %}

{% block footer %}
    {% include "layout/dashboardFooter.html.twig" %}
{% endblock %}